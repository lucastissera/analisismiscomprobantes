# Copiar a .env y ajustar (no subir .env a Git)

# --- Render / servidor online (recomendado, fuera del repo) ---
# JSON completo de usuarios (una sola línea). Ejemplo mínimo:
# AUTH_USERS_JSON={"version":1,"users":{"Lucas":{"password":"Lucas1992.","rol":"admin","valido_hasta":"2027-06-08"}}}
# Token para que los portables descarguen el listado desde /api/auth-users
# AUTH_USERS_REMOTE_TOKEN=token-secreto-largo
# Usuario administrador por entorno (opcional, refuerzo de "rol":"admin" en el JSON)
# AUTH_ADMIN_USER=Lucas

# --- Portables: sync desde el servidor Render ---
# AUTH_USERS_URL=https://tu-app.onrender.com/api/auth-users
# AUTH_USERS_REMOTE_TOKEN=el-mismo-token-secreto-largo
# AUTH_USERS_REFRESH_SEC=120

# --- Modo local / desarrollo ---
# Copiá auth_users.example.json como auth_users.json (está en .gitignore)
# AUTH_USERS_PATH=C:/ruta/auth_users.json
# AUTH_DATA_DIR=C:/DatosAIC
# AUTH_USERS_CACHE_PATH=C:/DatosAIC/auth/auth_users_cache.json

# --- Respaldo de un solo usuario ---
# AUTH_ADMIN_USER=Lucas
# AUTH_ADMIN_PASSWORD=Lucas1992.

# --- Alta de usuarios por enlace (/solicitar-acceso) ---
# AUTH_ADMIN_NOTIFY_EMAIL=tu@mail.com
# AUTH_ADMIN_WHATSAPP=5493513132914
# AUTH_REGISTRATIONS_DIR=/var/data/aic_auth
# AUTH_ALTA_PUBLICA=1
# AUTH_ALTA_TOKEN_HORAS=72
# AUTH_MIN_PASSWORD_LEN=8
# AUTH_SUBSCRIPTION_DAYS=30
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=tu@mail.com
# SMTP_PASSWORD=app-password
# SMTP_FROM=tu@mail.com

# --- Cursor Cloud (solo panel admin en la web) ---
# API key: Cursor Dashboard → Integrations / API Keys (no commitear)
# CURSOR_API_KEY=
# Repo GitHub autorizado en la app de Cursor (para que el agente edite código)
# CURSOR_REPO_URL=https://github.com/tu-usuario/analisismiscomprobantes
# CURSOR_REPO_BRANCH=main
# CURSOR_MODEL=composer-2
# CURSOR_AUTO_CREATE_PR=1
# CURSOR_PUSH_DIRECT=0
# CURSOR_REQUIERE_REPO=1
# CURSOR_PROMPT_PREFIX=

# Enlace ARCA (descarga automática Mis Comprobantes)
# CUIT_EN_ARCA_UI=1
# CUIT_EN_ARCA_PLAYWRIGHT=1
# CUIT_EN_ARCA_HEADLESS=1  (servidor web; en el .exe omitir o =0 para ver el navegador)
